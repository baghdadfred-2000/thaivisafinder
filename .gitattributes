# Normalize line endings across the repo.
# Text files are stored with LF in Git and checked out as LF,
# which stops the "LF will be replaced by CRLF" warnings on Windows.
* text=auto eol=lf

# Explicit text types (web project)
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.svg   text eol=lf
*.txt   text eol=lf
*.md    text eol=lf

# Binary assets — never convert these
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
